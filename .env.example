# Copy to .env (or generate with: python scripts/install.py --backend pg)

# Backend profile: pg | mongo. Everything (events, subscriptions, delivery
# queue) lives in this one database.
WHE_BACKEND=pg

# Required — shared secret for producer / admin auth (X-Source-Key header)
WHE_SOURCE_KEY=change-me-to-a-random-secret

# ── Postgres profile (WHE_BACKEND=pg) ────────────────────────────────────────
WHE_PG_DSN=postgresql+asyncpg://localhost:5432/webhooks
WHE_PG_EVENTS_TABLE=wh_events
WHE_PG_SUBSCRIPTIONS_TABLE=wh_subscriptions
WHE_PG_DELIVERIES_TABLE=wh_deliveries
WHE_PG_ATTEMPTS_TABLE=wh_delivery_attempts

# ── Mongo profile (WHE_BACKEND=mongo) ────────────────────────────────────────
WHE_MONGO_DSN=mongodb://localhost:27017
WHE_MONGO_DB=webhooks
WHE_MONGO_EVENTS_COLLECTION=wh_events
WHE_MONGO_SUBSCRIPTIONS_COLLECTION=wh_subscriptions
WHE_MONGO_DELIVERIES_COLLECTION=wh_deliveries

# ── server + loops (defaults shown) ──────────────────────────────────────────
WHE_HOST=0.0.0.0
WHE_PORT=8080
WHE_DEBUG=false
WHE_POLL_INTERVAL_S=1.0
WHE_INGEST_POLL_INTERVAL_S=1.0
WHE_BATCH_SIZE=50
WHE_INGEST_BATCH_SIZE=100
WHE_WORKER_CONCURRENCY=20
WHE_LEASE_TTL_S=30
WHE_DRAIN_TIMEOUT_S=10.0
